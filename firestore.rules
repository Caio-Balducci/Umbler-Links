rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Perfis públicos — leitura pública, escrita somente do dono
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;

      // Links — leitura pública (ativos), escrita somente do dono
      match /links/{linkId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Cliques — qualquer um pode registrar, somente o dono lê
    match /clicks/{clickId} {
      allow create: if true;
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
